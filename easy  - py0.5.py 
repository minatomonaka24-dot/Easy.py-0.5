    },
    "English": {
        "title": "Master Custom Editor", 
        "label": "Enter Code:", 
        "btn": "▶ RUN", 
        "output": "Output:",
        "hint": "* Commands: let/print/cheer/if/else/loop/wait/rand/ask/join",
        "sample": "ask length = How many digits?\npassword res = length\ntype Password is:\nprint res\nbeep\nalert Done!"
    }
}

# --- 画面（GUI）の構築 ---
