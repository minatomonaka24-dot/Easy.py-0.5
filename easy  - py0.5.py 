label_out.pack(fill="x", padx=10, pady=(5, 2))
output_widget = tk.Text(root, height=8, bg="#f8f9fa", font=APP_FONT, state="disabled")
output_widget.pack(fill="both", expand=True, padx=10, pady=(2, 10))

